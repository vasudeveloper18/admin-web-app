{
  "info": {
    "name": "FieldOps API",
    "description": "API collection for the FieldOps job dispatch platform. All protected endpoints require a Bearer token in the Authorization header.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:3001",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@fieldops.com\",\n  \"password\": \"AdminPass123!\"\n}"
            },
            "url": "{{baseUrl}}/auth/login",
            "description": "Login with admin credentials. Automatically saves accessToken and refreshToken to collection variables."
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/refresh",
            "description": "Rotate access and refresh tokens. Old refresh token is invalidated."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/auth/logout",
            "description": "Logout and invalidate the current refresh token."
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/me",
            "description": "Get the currently authenticated admin user's profile."
          }
        },
        {
          "name": "Get All Technicians",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/technicians",
            "description": "Get a list of all technician users for assignment."
          }
        }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        {
          "name": "Create Job",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"HVAC Maintenance\",\n  \"description\": \"Seasonal inspection and filter replacement.\",\n  \"customerName\": \"John Doe\",\n  \"customerPhone\": \"617-555-0101\",\n  \"customerEmail\": \"john.doe@example.com\",\n  \"address\": \"100 Boylston St, Boston, MA\",\n  \"latitude\": 42.3535,\n  \"longitude\": -71.0643,\n  \"scheduledDate\": \"2026-08-15T10:00:00Z\"\n}"
            },
            "url": "{{baseUrl}}/jobs",
            "description": "Create a new service job."
          }
        },
        {
          "name": "Get All Jobs (Paginated)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/jobs?page=1&limit=10&sortBy=scheduledDate&sortOrder=desc",
              "host": ["{{baseUrl}}"],
              "path": ["jobs"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "sortBy", "value": "scheduledDate" },
                { "key": "sortOrder", "value": "desc" }
              ]
            },
            "description": "Get paginated list of jobs."
          }
        },
        {
          "name": "Get Jobs - Filter by Status",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/jobs?page=1&limit=10&status=PENDING",
              "host": ["{{baseUrl}}"],
              "path": ["jobs"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "status", "value": "PENDING" }
              ]
            }
          }
        },
        {
          "name": "Get Jobs - Search",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/jobs?search=HVAC&page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["jobs"],
              "query": [
                { "key": "search", "value": "HVAC" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get Jobs - Date Range Filter",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/jobs?startDate=2026-01-01T00:00:00Z&endDate=2026-12-31T23:59:59Z&page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["jobs"],
              "query": [
                { "key": "startDate", "value": "2026-01-01T00:00:00Z" },
                { "key": "endDate", "value": "2026-12-31T23:59:59Z" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get Job by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/jobs/JOB_ID_HERE",
            "description": "Replace JOB_ID_HERE with a valid MongoDB ObjectId."
          }
        },
        {
          "name": "Assign Technician to Job",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"technicianId\": \"TECHNICIAN_ID_HERE\"\n}"
            },
            "url": "{{baseUrl}}/jobs/JOB_ID_HERE/assign",
            "description": "Assign a technician to a job. Job must not be COMPLETED or CANCELLED."
          }
        },
        {
          "name": "Unassign Technician from Job",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/jobs/JOB_ID_HERE/unassign",
            "description": "Unassign the current technician from a job."
          }
        },
        {
          "name": "Cancel Job",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Customer requested cancellation due to scheduling conflict.\"\n}"
            },
            "url": "{{baseUrl}}/jobs/JOB_ID_HERE/cancel",
            "description": "Cancel a job with a required reason. Job must not be COMPLETED."
          }
        }
      ]
    },
    {
      "name": "Mobile (Technician) — Start & Complete",
      "description": "New mobile endpoints only. Use auth/login first to set accessToken.",
      "item": [
        {
          "name": "Technician Login (get token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"marcus@fieldops.com\",\n  \"password\": \"TechPass123!\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Start Job",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/jobs/JOB_ID_HERE/start",
            "description": "ASSIGNED → IN_PROGRESS. No body. Job must be assigned to logged-in technician."
          }
        },
        {
          "name": "Complete Job (multipart)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "completionNotes", "value": "Replaced filter and verified system operation.", "type": "text" },
                { "key": "photos", "type": "file", "src": [] }
              ]
            },
            "url": "{{baseUrl}}/jobs/JOB_ID_HERE/complete",
            "description": "IN_PROGRESS → COMPLETED. multipart: completionNotes + photos (one or more image files)."
          }
        }
      ]
    }
  ]
}
